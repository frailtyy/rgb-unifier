{
  "name": "rgb-unifier",
  "version": "1.0.0",
  "description": "Desktop app to unify PC RGB and hardware settings.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:electron\" \"npm:dev:renderer\"",
    "dev:electron": "ts-node electron/main.ts",
    "dev:renderer": "vite",
    "build": "vite build && tsc -p .",
    "package": "electron-builder"
  },
  "author": "Bea Provis",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "lucide-react": "^0.362.0",
    "tailwindcss": "^3.4.0",
    "node-hid": "^2.1.2",
    "openrgb-sdk": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "vite": "^5.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.7.0",
    "@electron/remote": "^2.1.5",
    "postcss": "^8.4.31",
    "autoprefixer": "^10.4.15"
  },
  "build": {
    "appId": "com.beaprovis.rgbunifier",
    "productName": "RGB Unifier",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**",
      "electron/**",
      "src/**",
      "node_modules/**",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    }
  }
}